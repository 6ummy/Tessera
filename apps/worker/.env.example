# Copy to .env and fill. .env is gitignored.

# Environment
ENV=development
LOG_LEVEL=INFO

# Database (Neon connection string)
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/tessera?sslmode=require

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MAX_DAILY_COST_USD=20.0

# Brokerage (Alpaca paper)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market data
FMP_API_KEY=
FRED_API_KEY=
NEWSAPI_API_KEY=
# SEC EDGAR — no API key, but User-Agent with contact is required.
# Format: "Tessera Pilot you@example.com" (SEC 403s requests without contact info).
SEC_USER_AGENT=Tessera Pilot you@example.com

# Inter-service auth (Vercel cron <-> Cloud Run worker)
WORKER_WEBHOOK_SECRET=

# Object storage
GCS_BUCKET_RAW=tessera-raw

# Feature flags
FEATURE_REAL_LLM=false
FEATURE_PAPER_EXECUTION=false
FEATURE_LIVE_TRADING=false

# Observability — Sentry DSN for the tessera-worker project (FastAPI).
# Get from sentry.io → Projects → tessera-worker. Blank → Sentry disabled.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

