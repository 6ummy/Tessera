# Copy to .env.local and fill. .env.local is gitignored.
# (Next.js convention: .env.local is the active local-dev file, never committed.)
#
# For Vercel deploys, set these same vars in:
#   Vercel project → Settings → Environment Variables
#   (apply to Production / Preview / Development as needed)

# Vercel Cron auth — must match the value set in Vercel project env.
# Generate a random secret: `openssl rand -hex 32` or any password manager.
CRON_SECRET=

# Worker webhook (Phase A: leave blank → cron returns noop)
# Phase B Week 2: set to the deployed Cloud Run URL.
WORKER_WEBHOOK_URL=
WORKER_WEBHOOK_SECRET=

# Observability — Sentry DSN for the Next.js project (tessera-web).
# SENTRY_DSN          → used by server-side (Edge + Node runtimes)
# NEXT_PUBLIC_SENTRY_DSN → exposed to the browser bundle (must start with NEXT_PUBLIC_)
# Both should hold the SAME web DSN. Get it from sentry.io → Projects → tessera-web.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
