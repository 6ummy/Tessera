{
  "__inputs": [
    {
      "name": "DS_NEON",
      "label": "Neon Postgres (read-only)",
      "description": "PostgreSQL datasource pointed at the Tessera Neon DB with the read-only grafana role",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "title": "Tessera — LLM cost & calls",
  "uid": "tessera-llm-cost",
  "tags": ["tessera", "llm", "cost"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Spend today (global cap $5)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(cost_usd), 0) AS spent FROM llm_call_log WHERE ts >= CURRENT_DATE;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Chat pool today (cap $2)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(cost_usd), 0) AS chat_spent FROM llm_call_log WHERE ts >= CURRENT_DATE AND stage = 'chat';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.2 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Spend this month",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(cost_usd), 0) AS month_spent FROM llm_call_log WHERE ts >= date_trunc('month', CURRENT_DATE);"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed calls (7d)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS failed FROM llm_call_log WHERE ts >= now() - interval '7 days' AND NOT success;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Daily LLM cost by stage",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('day', ts) AS \"time\", stage AS metric, SUM(cost_usd) AS value FROM llm_call_log WHERE ts >= now() - interval '30 days' GROUP BY 1, 2 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 70 }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Cost by persona (7d)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(persona_id, '(system)') AS persona, SUM(cost_usd) AS cost FROM llm_call_log WHERE ts >= now() - interval '7 days' GROUP BY 1 ORDER BY 2 DESC;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Calls / tokens / latency by stage (7d)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_NEON}" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT stage, COUNT(*) AS calls, SUM(tokens_in) AS tokens_in, SUM(tokens_out) AS tokens_out, SUM(cached_tokens) AS cached, ROUND(AVG(latency_ms)) AS avg_latency_ms, ROUND(SUM(cost_usd)::numeric, 4) AS cost_usd FROM llm_call_log WHERE ts >= now() - interval '7 days' GROUP BY stage ORDER BY cost_usd DESC;"
        }
      ]
    }
  ]
}
